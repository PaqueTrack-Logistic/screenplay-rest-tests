# Configuracion de las pruebas de UI por AMBIENTE (no se quema en el codigo).
# Copia este archivo a .env y ajustalo segun tu ambiente.
#
# Prioridad de resolucion (mayor a menor):
#   -Dui.baseurl=... / -Dui.delay.ms=...   (override por consola)
#   .env  (este archivo)                    -> config por ambiente / dev
#   serenity.conf (ui.baseurl, ui.delay.ms) -> fallback versionado
#   valor por defecto

# URL del front a probar. El front puede vivir en un ambiente DISTINTO al del
# backend: basta apuntar esto al front del ambiente (local, QA, staging...).
UI_BASEURL=http://localhost:5173

# Delay "solo para observar" la prueba en vivo, en milisegundos.
#   0    -> sin pausa  (VALOR PRODUCTIVO: la suite corre con esperas explicitas)
#   2000 -> pausa de 2s antes de cada accion decisiva (util para sustentar/socializar)
UI_DELAY_MS=0
